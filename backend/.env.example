# Copy to .env and fill in values

# FHIR server
FHIR_BASE_URL=https://hapi.fhir.org/baseR4
FHIR_AUTH_TOKEN=

# Azure AI Foundry
# Project endpoint from Foundry portal home page (append /agents/v1.0 is handled by SDK)
AZURE_PROJECT_ENDPOINT=https://<your-project>.services.ai.azure.com
AZURE_API_KEY=<your-api-key>

# Agent ID — create the agent in Foundry portal (Agents tab),
# attach the Foundry IQ knowledge base, then paste the agent ID here
AZURE_AGENT_ID=asst_xxxxxxxxxxxxxxxx

# Frontend origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173
